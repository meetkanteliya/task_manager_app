datasource db {
  provider = "postgresql"
  schemas  = ["taskflow"]
}

generator client {
  provider        = "prisma-client"
  output          = "../src/generated/prisma"
  previewFeatures = ["multiSchema"]
}

enum Role {
  ADMIN
  MANAGER
  MEMBER
  VIEWER

  @@schema("taskflow")
}

enum TaskPriority {
  low
  medium
  high

  @@schema("taskflow")
}

model User {
  id         String     @id @default(cuid())
  name       String?
  email      String     @unique
  password   String
  role       Role       @default(MEMBER) 
  createdAt  DateTime   @default(now())
  tasks      Task[]
  activities Activity[]

  // Project relations
  ownedProjects             Project[]        @relation("OwnedProjects")
  projectMembers            ProjectMember[]
  assignedProjectTasks      ProjectTask[]    @relation("AssignedProjectTasks")
  createdProjectTasks       ProjectTask[]    @relation("CreatedProjectTasks")
  assignedProjectSubtasks   ProjectSubtask[] @relation("AssignedProjectSubtasks")

  @@schema("taskflow")
}

model Task {
  id          String       @id @default(cuid())
  title       String
  description String?
  completed   Boolean      @default(false)
  completedAt DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  dueDate     DateTime?
  priority    TaskPriority @default(medium)
  userId      String
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  subtasks    Subtask[]

  @@index([userId])
  @@schema("taskflow")
}

model Subtask {
  id        String  @id @default(cuid())
  title     String
  completed Boolean @default(false)
  taskId    String
  task      Task    @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@schema("taskflow")
}

model Activity {
  id        String   @id @default(cuid())
  type      String
  message   String
  createdAt DateTime @default(now())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@schema("taskflow")
}

// ─── Project & Team Management ───────────────────────────────────

model Project {
  id          String          @id @default(cuid())
  name        String
  description String?
  ownerId     String
  owner       User            @relation("OwnedProjects", fields: [ownerId], references: [id], onDelete: Cascade)
  members     ProjectMember[]
  tasks       ProjectTask[]
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@schema("taskflow")
}

model ProjectMember {
  id        String   @id @default(cuid())
  projectId String
  userId    String
  isLeader  Boolean  @default(false)
  joinedAt  DateTime @default(now())
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@schema("taskflow")
}

model ProjectTask {
  id          String           @id @default(cuid())
  title       String
  description String?
  completed   Boolean          @default(false)
  completedAt DateTime?
  priority    TaskPriority     @default(medium)
  dueDate     DateTime?
  projectId   String
  assigneeId  String?
  createdById String
  project     Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assignee    User?            @relation("AssignedProjectTasks", fields: [assigneeId], references: [id])
  createdBy   User             @relation("CreatedProjectTasks", fields: [createdById], references: [id])
  subtasks    ProjectSubtask[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@schema("taskflow")
}

model ProjectSubtask {
  id            String      @id @default(cuid())
  title         String
  completed     Boolean     @default(false)
  projectTaskId String
  assigneeId    String?
  projectTask   ProjectTask @relation(fields: [projectTaskId], references: [id], onDelete: Cascade)
  assignee      User?       @relation("AssignedProjectSubtasks", fields: [assigneeId], references: [id])

  @@schema("taskflow")
}
