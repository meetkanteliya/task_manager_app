datasource db {
  provider = "postgresql"
  schemas  = ["taskflow"]
}

generator client {
  provider        = "prisma-client"
  output          = "../src/generated/prisma"
  previewFeatures = ["multiSchema"]
}

enum Role {
  ADMIN
  MANAGER
  MEMBER
  VIEWER

  @@schema("taskflow")
}

enum TaskPriority {
  low
  medium
  high

  @@schema("taskflow")
}

model User {
  id         String     @id @default(cuid())
  name       String?
  email      String     @unique
  password   String
  role       Role       @default(MEMBER) 
  createdAt  DateTime   @default(now())
  tasks      Task[]
  activities Activity[]

  @@schema("taskflow")
}

model Task {
  id          String       @id @default(cuid())
  title       String
  description String?
  completed   Boolean      @default(false)
  completedAt DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  dueDate     DateTime?
  priority    TaskPriority @default(medium)
  userId      String
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  subtasks    Subtask[]

  @@index([userId])
  @@schema("taskflow")
}

model Subtask {
  id        String  @id @default(cuid())
  title     String
  completed Boolean @default(false)
  taskId    String
  task      Task    @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@schema("taskflow")
}

model Activity {
  id        String   @id @default(cuid())
  type      String
  message   String
  createdAt DateTime @default(now())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@schema("taskflow")
}
